#!/bin/bash

[ -n "$1" -a "x$1" != "x-e" ] && default_cut_time="$1" && shift
[ "x$1" = "x-e" ] && unset default_cut_time && shift

group_cut_time=5

cat liste | grep -i [a-z] | while read index foo
do
  nr=$(echo $index | sed "s/[^0-9].*//")
  grep -q "^$nr.mov" .rethumbed 2>/dev/null && continue
  grep "^$nr.mov" times | while read f f movie_length
  do
    echo "$foo" | grep -q "," \
    && d=$group_cut_time \
    || {
      [ "$default_cut_time" ] && d=$default_cut_time || d=$(($movie_length));
    }
    while [ $d -ge 0 ]
    do
      qt-thumbnailswide.sh -f -l -$d $nr.mov
      du -sh .browsercache/$nr-thumb.jpg | grep ^0 && d=$(($d - 1)) && echo retrying && continue
      echo "$nr.mov" >> .rethumbed
      echo "$nr" > .$1.thumbtime
      break
    done
  done
done
